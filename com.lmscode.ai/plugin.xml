<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

   <!-- ============ Commands ============ -->
   <extension point="org.eclipse.ui.commands">
      <category
            id="com.lmscode.ai.category"
            name="LMS Code">
      </category>
      <command
            id="com.lmscode.ai.commands.refactor"
            categoryId="com.lmscode.ai.category"
            name="Refactor"
            description="Refactor the selected code (including code in subfolders) using the configured AI">
      </command>
      <command
            id="com.lmscode.ai.commands.fixIssues"
            categoryId="com.lmscode.ai.category"
            name="Fix Issues"
            description="Send the selected problems or whole files to the AI and show fixes in the LMS Response view">
      </command>
      <command
            id="com.lmscode.ai.commands.compile"
            categoryId="com.lmscode.ai.category"
            name="Compile"
            description="Run a deep Maven/Gradle compile and analyze the build output with the AI">
      </command>
      <command
            id="com.lmscode.ai.commands.dependency"
            categoryId="com.lmscode.ai.category"
            name="Dependency"
            description="Analyze project dependencies (pom.xml / Gradle) for vulnerabilities and suggested fixes">
      </command>
      <command
            id="com.lmscode.ai.commands.chat"
            categoryId="com.lmscode.ai.category"
            name="Chat"
            description="Open the LMS Chat view with the current selection as context">
      </command>
   </extension>

   <!-- ============ Handlers ============ -->
   <extension point="org.eclipse.ui.handlers">
      <handler
            commandId="com.lmscode.ai.commands.refactor"
            class="com.lmscode.ai.handlers.RefactorHandler">
      </handler>
      <handler
            commandId="com.lmscode.ai.commands.fixIssues"
            class="com.lmscode.ai.handlers.FixIssuesHandler">
      </handler>
      <handler
            commandId="com.lmscode.ai.commands.compile"
            class="com.lmscode.ai.handlers.CompileHandler">
      </handler>
      <handler
            commandId="com.lmscode.ai.commands.dependency"
            class="com.lmscode.ai.handlers.DependencyAnalysisHandler">
      </handler>
      <handler
            commandId="com.lmscode.ai.commands.chat"
            class="com.lmscode.ai.handlers.OpenChatHandler">
      </handler>
   </extension>

   <!-- ============ Context menu: right click anywhere ============ -->
   <extension point="org.eclipse.ui.menus">
      <menuContribution locationURI="popup:org.eclipse.ui.popup.any?after=additions">
         <menu
               id="com.lmscode.ai.menu"
               label="LMS Code"
               icon="icons/monkey16.png">
            <command
                  commandId="com.lmscode.ai.commands.refactor"
                  label="Refactor"
                  icon="icons/monkey16.png"
                  style="push">
            </command>
            <command
                  commandId="com.lmscode.ai.commands.fixIssues"
                  label="Fix Issues"
                  icon="icons/monkey16.png"
                  style="push">
            </command>
            <command
                  commandId="com.lmscode.ai.commands.compile"
                  label="Compile"
                  icon="icons/monkey16.png"
                  style="push">
            </command>
            <command
                  commandId="com.lmscode.ai.commands.dependency"
                  label="Dependency"
                  icon="icons/monkey16.png"
                  style="push">
            </command>
            <command
                  commandId="com.lmscode.ai.commands.chat"
                  label="Chat"
                  icon="icons/monkey16.png"
                  style="push">
            </command>
         </menu>
      </menuContribution>
   </extension>

   <!-- ============ Views ============ -->
   <extension point="org.eclipse.ui.views">
      <category
            id="com.lmscode.ai.viewCategory"
            name="LMS Code">
      </category>
      <view
            id="com.lmscode.ai.views.chatView"
            name="LMS Chat"
            category="com.lmscode.ai.viewCategory"
            class="com.lmscode.ai.views.ChatView"
            icon="icons/monkey16.png"
            restorable="true">
      </view>
      <view
            id="com.lmscode.ai.views.dependencyView"
            name="LMS Dependency"
            category="com.lmscode.ai.viewCategory"
            class="com.lmscode.ai.views.DependencyView"
            icon="icons/monkey16.png"
            restorable="true">
      </view>
      <view
            id="com.lmscode.ai.views.responseView"
            name="LMS Response"
            category="com.lmscode.ai.viewCategory"
            class="com.lmscode.ai.views.ResponseView"
            icon="icons/monkey16.png"
            restorable="true">
      </view>
   </extension>

   <!-- ============ Preferences ============ -->
   <extension point="org.eclipse.ui.preferencePages">
      <page
            id="com.lmscode.ai.preferences.page"
            name="LMS Code AI"
            class="com.lmscode.ai.preferences.LmsCodePreferencePage">
      </page>
   </extension>
   <extension point="org.eclipse.core.runtime.preferences">
      <initializer class="com.lmscode.ai.preferences.PreferenceInitializer">
      </initializer>
   </extension>

</plugin>
